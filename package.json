{
  "name": "claude-echo",
  "displayName": "Claude Echo",
  "description": "Chat with your Claude Code agent from WhatsApp, Telegram, Discord, or Slack.",
  "version": "0.4.1",
  "publisher": "codenzia",
  "author": {
    "name": "Codenzia",
    "url": "https://codenzia.com"
  },
  "license": "MIT",
  "homepage": "https://codenzia.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Codenzia/claude-echo"
  },
  "bugs": {
    "url": "https://github.com/Codenzia/claude-echo/issues"
  },
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "whatsapp",
    "telegram",
    "discord",
    "slack",
    "bridge",
    "remote",
    "agent",
    "codenzia"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/icon-marketplace.png",
  "galleryBanner": {
    "color": "#181C24",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      { "command": "claudeEcho.bindSessions", "title": "Claude Echo: Bind Claude Code sessions…", "icon": "$(link)" },
      { "command": "claudeEcho.unbindOne", "title": "Claude Echo: Unbind a single session…", "icon": "$(remove)" },
      { "command": "claudeEcho.setActive", "title": "Claude Echo: Change active session…", "icon": "$(star-empty)" },
      { "command": "claudeEcho.unbind", "title": "Claude Echo: Remove workspace binding", "icon": "$(unlink)" },
      { "command": "claudeEcho.start", "title": "Claude Echo: Start bridge", "icon": "$(play)" },
      { "command": "claudeEcho.stop", "title": "Claude Echo: Stop bridge", "icon": "$(debug-stop)" },
      { "command": "claudeEcho.showQR", "title": "Claude Echo: Show WhatsApp QR code", "icon": "$(device-mobile)" },
      { "command": "claudeEcho.testSend", "title": "Claude Echo: Send test message", "icon": "$(send)" },
      { "command": "claudeEcho.refresh", "title": "Claude Echo: Refresh", "icon": "$(refresh)" },
      { "command": "claudeEcho.showLogs", "title": "Claude Echo: Show logs", "icon": "$(output)" },
      { "command": "claudeEcho.resetAuth", "title": "Claude Echo: Reset gateway auth", "icon": "$(refresh)" },
      { "command": "claudeEcho.regenerateChallenge", "title": "Claude Echo: Regenerate verification code (WhatsApp)", "icon": "$(key)" },
      { "command": "claudeEcho.showChallenge", "title": "Claude Echo: Show verification code (WhatsApp)", "icon": "$(eye)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeEcho",
          "title": "Claude Echo",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claudeEcho": [
        {
          "id": "claudeEcho.main",
          "name": "Bridge",
          "icon": "resources/icon.svg",
          "contextualTitle": "Claude Echo"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeEcho.main",
        "contents": "No Claude Code sessions bound yet.\n\nChat with your Claude Code agent from WhatsApp, Telegram, Discord, or Slack. Bind one or more sessions and route between them with tags.\n\n[Bind Claude Code sessions…](command:claudeEcho.bindSessions)\n\nDeveloped by [Codenzia](https://codenzia.com)."
      }
    ],
    "menus": {
      "view/title": [
        { "command": "claudeEcho.bindSessions", "when": "view == claudeEcho.main", "group": "navigation@1" },
        { "command": "claudeEcho.start", "when": "view == claudeEcho.main && !claudeEcho:running", "group": "navigation@2" },
        { "command": "claudeEcho.stop", "when": "view == claudeEcho.main && claudeEcho:running", "group": "navigation@2" },
        { "command": "claudeEcho.showLogs", "when": "view == claudeEcho.main", "group": "navigation@3" },
        { "command": "claudeEcho.refresh", "when": "view == claudeEcho.main", "group": "navigation@4" }
      ]
    },
    "configuration": {
      "title": "Claude Echo",
      "properties": {
        "claudeEcho.claudeCliPath": {
          "type": "string",
          "default": "claude",
          "scope": "machine",
          "description": "Path to the Claude Code CLI binary. Locked to user/machine scope so a malicious workspace cannot redirect the bridge."
        },
        "claudeEcho.responseTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "description": "Maximum time (ms) to wait for the Claude CLI to respond before sending a timeout reply."
        },
        "claudeEcho.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the bridge on workspace activation when a verified binding exists."
        },
        "claudeEcho.maxMessagesPerHour": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "Drop inbound messages above this rate. 0 disables."
        },
        "claudeEcho.maxMessagesPerDay": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "Same, per rolling 24 hours."
        },
        "claudeEcho.maxInboundBytes": {
          "type": "number",
          "default": 4096,
          "minimum": 256,
          "description": "Truncate inbound bodies to this many bytes."
        },
        "claudeEcho.verboseLogging": {
          "type": "boolean",
          "default": false,
          "description": "Log full message bodies in the Output Channel and Activity tree. Off by default for privacy."
        },
        "claudeEcho.telegram.botToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Telegram bot token from @BotFather (looks like 1234567:AAE…). Required for the Telegram gateway."
        },
        "claudeEcho.discord.botToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Discord bot token from https://discord.com/developers/applications. Required for the Discord gateway. The bot must have the MESSAGE_CONTENT privileged intent enabled."
        },
        "claudeEcho.slack.appToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Slack app-level token starting with xapp-. Required for the Slack gateway (Socket Mode)."
        },
        "claudeEcho.slack.botToken": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Slack bot token starting with xoxb-. Required for the Slack gateway. Needs scopes: chat:write, im:history, im:read."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.10.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "discord.js": "^14.16.3",
    "qrcode": "^1.5.3"
  }
}
